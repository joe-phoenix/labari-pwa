{
  "name": "Labari Media - Beyond The Surface",
  "short_name": "Labari",
  "description": "Pan-African tech and culture journalism, curated from TechLabari and Labari Journal. Read offline, get breaking news alerts.",
  "start_url": "/?source=pwa",
  "id": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait-primary",
  "background_color": "#F5F2EC",
  "theme_color": "#0A0A0A",
  "lang": "en",
  "dir": "ltr",
  "categories": ["news", "magazines"],
  "icons": [
    { "src": "/icons/icon-72.png", "sizes": "72x72", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-96.png", "sizes": "96x96", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-128.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192-maskable.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    {
      "src": "/screenshots/home-mobile.png",
      "sizes": "1080x2340",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home feed with unified TechLabari and Labari Journal stories"
    },
    {
      "src": "/screenshots/home-desktop.png",
      "sizes": "2560x1440",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop reading view with dark mode"
    }
  ],
  "shortcuts": [
    {
      "name": "TechLabari",
      "short_name": "Tech",
      "description": "Jump straight to TechLabari coverage",
      "url": "/?source=techlabari",
      "icons": [{ "src": "/icons/shortcut-tech.png", "sizes": "96x96" }]
    },
    {
      "name": "Labari Journal",
      "short_name": "Journal",
      "description": "Jump straight to Labari Journal coverage",
      "url": "/?source=labari-journal",
      "icons": [{ "src": "/icons/shortcut-journal.png", "sizes": "96x96" }]
    },
    {
      "name": "Bookmarks",
      "short_name": "Saved",
      "description": "Your saved articles, available offline",
      "url": "/bookmarks",
      "icons": [{ "src": "/icons/shortcut-bookmarks.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  },
  "edge_side_panel": { "preferred_width": 420 },
  "launch_handler": { "client_mode": "focus-existing" }
}
